{
  "name": "@shuangwhywhy/quota-guard",
  "version": "1.4.0",
  "description": "Zero-intrusion AI Call Guard and debug cost-saving kernel for model invocations",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shuangwhywhy/ai-quota-guard.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./register": {
      "import": "./dist/register.mjs",
      "require": "./dist/register.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    },
    "./axios": {
      "types": "./dist/axios.d.ts",
      "import": "./dist/axios.mjs",
      "require": "./dist/axios.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "ai",
    "llm",
    "token",
    "rate-limit",
    "quota",
    "guard",
    "debug",
    "debug-mode",
    "mock",
    "hook",
    "zero-intrusion",
    "non-intrusive",
    "interceptor",
    "cost-saving"
  ],
  "author": "qyz",
  "license": "MIT",
  "dependencies": {
    "@mswjs/interceptors": "^0.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@eslint/js": "^9.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.2.0",
    "typescript-eslint": "^8.13.0",
    "jsdom": "^29.0.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "5.4.21",
    "vitest": "^1.6.1"
  }
}
