{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "vitest.config.ts",
    "vitest.workspace.ts",
    "tsup.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
