#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Ensure Node/npm is in PATH for macOS/Brew environments
export PATH="$PATH:/usr/local/bin:/opt/homebrew/bin"

# Check if on main branch (direct commit lock)
branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" = "main" ]; then
  echo "❌ Error: Direct commits/merges to 'main' are forbidden."
  echo "Please use a feature/fix branch and submit a PR on GitHub."
  exit 1
fi
